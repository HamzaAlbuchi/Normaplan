# BauPilot Web – production build served on 0.0.0.0:PORT
FROM node:20-slim AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/types/package.json ./packages/types/
COPY packages/rule-engine/package.json ./packages/rule-engine/

RUN pnpm install

COPY packages/types ./packages/types
COPY packages/rule-engine ./packages/rule-engine
COPY apps/web ./apps/web

# Build web only (web app does not use @baupilot/types or rule-engine)
ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL:-/api}
ENV NODE_OPTIONS=--max-old-space-size=4096
RUN pnpm --filter web build

# Production: only serve static files
FROM node:20-slim AS runner
WORKDIR /app

COPY --from=builder /app/apps/web/dist ./dist
COPY --from=builder /app/apps/web/scripts ./scripts
COPY --from=builder /app/apps/web/package.json ./package.json

# Fail the build if dist wasn't produced (so 502 isn't from empty dist)
RUN test -f ./dist/index.html && echo "dist OK" || (echo "ERROR: dist/index.html missing" && exit 1)

ENV NODE_ENV=production
ENV PORT=3000
EXPOSE 3000

# Use shell so PORT from Railway is available; listen on 0.0.0.0
CMD ["sh", "-c", "exec node scripts/serve.mjs"]
