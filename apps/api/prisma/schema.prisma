// BauPilot – Database schema
// PostgreSQL
// Multi-user architecture office workspace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles: owner, manager, architect, reviewer, viewer
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships         Membership[]
  projectAssignments  ProjectAssignment[]
  violationDecisions  RuleViolation[]     @relation("decidedBy")
  reviewHistory       ViolationReview[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  projects    Project[]
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   // owner | manager | architect | reviewer | viewer
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  zipCode        String
  state          String
  organizationId String
  projectType    String?  // residential | commercial | mixed_use | industrial | education | healthcare | other
  status         String   @default("ongoing") // ongoing | paused | ended
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  ProjectAssignment[]
  plans        Plan[]
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// Reusable analysis artifact: keyed by file hash + pipeline compatibility.
// Independent from Plan; multiple Plans can link to the same artifact.
// Deleting a Plan must NOT delete the artifact so future uploads can reuse it.
model AnalysisArtifact {
  id                    String   @id @default(cuid())
  fileHash              String   // SHA-256 hex
  sourceType            String   // PDF | IFC | DWG | IMAGE | JSON | UNKNOWN
  extractorStrategy     String   // GEMINI_PDF | PDF_FALLBACK | IFC_NATIVE | JSON_MOCK | DWG_AI | IMAGE_VISION | UNKNOWN
  extractionVersion     String
  rulesVersion          String
  promptVersion         String
  modelVersion          String
  originalFilename      String?
  mimeType              String?
  fileSize              Int?
  normalizedPlanJson    String   // PlanElements JSON
  deterministicFindingsJson String? // optional, for future rule-run caching
  aiFindingsJson        String?  // optional, for future AI violation caching
  createdAt             DateTime @default(now())
  lastUsedAt            DateTime @default(now())
  reuseCount            Int      @default(1)
  expiresAt             DateTime
  isPinned              Boolean  @default(false)

  plans Plan[]

  @@unique([fileHash, sourceType, extractorStrategy, extractionVersion, rulesVersion, promptVersion, modelVersion])
  @@index([fileHash])
  @@index([expiresAt])
}

model Plan {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisArtifactId   String?  // nullable: links to reusable artifact when reused or after fresh extraction
  analysisArtifact     AnalysisArtifact? @relation(fields: [analysisArtifactId], references: [id], onDelete: SetNull)
  name                 String
  fileName             String
  filePath             String?
  status               String   @default("uploaded")
  extractionError      String?
  elementsJson         String?  // copy for rule runs; also populated from artifact when linking
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  runs RuleRun[]

  @@index([analysisArtifactId])
}

model RuleRun {
  id             String   @id @default(cuid())
  planId         String
  plan           Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  checkedAt      DateTime @default(now())
  ruleVersion    String?
  violationCount Int      @default(0)
  warningCount   Int      @default(0)
  errorCount     Int      @default(0)

  violations RuleViolation[]
}

model RuleViolation {
  id              String   @id @default(cuid())
  runId           String
  run             RuleRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  ruleId          String
  ruleName        String
  severity        String   // info | warning | error (mapped to critical in API)
  message         String
  suggestion      String?
  elementIds      String[]
  actualValue     Float?
  requiredValue   Float?
  regulationRef   String?
  status          String   @default("open") // open | confirmed | dismissed | deferred | resolved
  reason          String?
  comment         String?
  decidedByUserId String?
  decidedBy       User?    @relation("decidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  updatedAt       DateTime @updatedAt

  reviewHistory ViolationReview[]
}

model ViolationReview {
  id          String   @id @default(cuid())
  violationId String
  violation   RuleViolation @relation(fields: [violationId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  reason      String?
  comment     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([violationId])
}
